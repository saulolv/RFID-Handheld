<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LocalizadorRFID" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="ConnLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/signal_haze</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ConnField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@drawable/bg_edittext</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/signal_frost</item>
        <item name="android:textColorHint">@color/signal_haze</item>
        <item name="android:textSize">16sp</item>
        <item name="android:importantForAutofill">no</item>
    </style>
</resources>
