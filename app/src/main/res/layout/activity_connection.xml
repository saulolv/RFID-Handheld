<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/signal_ink"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/conn_title"
            android:textColor="@color/signal_frost"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Status atual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_dot" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/conn_status_disconnected"
                android:textColor="@color/signal_frost"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQueued"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/signal_haze"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            style="@style/ConnLabel"
            android:text="@string/conn_url_label" />

        <EditText
            android:id="@+id/etUrl"
            style="@style/ConnField"
            android:hint="@string/conn_url_hint"
            android:inputType="textUri" />

        <TextView
            style="@style/ConnLabel"
            android:text="@string/conn_device_label" />

        <EditText
            android:id="@+id/etDevice"
            style="@style/ConnField"
            android:hint="@string/conn_device_hint"
            android:inputType="text" />

        <TextView
            style="@style/ConnLabel"
            android:text="@string/conn_token_label" />

        <EditText
            android:id="@+id/etToken"
            style="@style/ConnField"
            android:hint="@string/conn_token_hint"
            android:inputType="textNoSuggestions" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:checked="true"
            android:text="@string/conn_auto_send"
            android:textColor="@color/signal_frost"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btConnect"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_start"
            android:text="@string/conn_connect"
            android:textColor="@color/signal_frost"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btTest"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_surface"
                android:text="@string/conn_test"
                android:textColor="@color/signal_frost"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btWifi"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_surface"
                android:text="@string/conn_wifi"
                android:textColor="@color/signal_frost"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
